{
"$schema": "https://json.schemastore.org/chrome-manifest",
  "manifest_version": 3,
  "name": "WhatsApp Title Watcher",
  "version": "1.0",
  "description": "Watches WhatsApp title changes and pushes events locally.",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"]
    }
  ],
  "host_permissions": [
    "http://localhost:63845/*",
    "http://127.0.0.1:63845/*"
  ],
  "permissions": []
  ,
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}